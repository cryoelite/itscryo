---
import Layout from "../layouts/layout.astro";
---

<Layout
  title="Contact"
  description="Contact Arvind Sagar for backend, systems, and infrastructure opportunities."
  currentPath="/contact"
>
  <section class="page-intro">
    <p class="eyebrow">Contact</p>
    <h1>Open to backend and systems work with real technical depth.</h1>
    <p>
      Interested in backend and systems roles, early-stage startups, and
      technically challenging problems.
    </p>
  </section>

  <section class="grid grid-2">
    <article class="panel contact-card">
      <p class="section-label">Direct</p>
      <h2>Email</h2>
      <a href="mailto:itsarvindsagar@gmail.com">itsarvindsagar@gmail.com</a>
    </article>

    <article class="panel contact-card">
      <p class="section-label">Code</p>
      <h2>GitHub</h2>
      <a href="https://github.com/cryoelite" target="_blank" rel="noreferrer">
        github.com/cryoelite
      </a>
    </article>

    <article class="panel contact-card">
      <p class="section-label">Location</p>
      <h2>Base</h2>
      <p>Lucknow, India</p>
    </article>

    <article class="panel contact-card">
      <p class="section-label">Open To</p>
      <h2>Work</h2>
      <ul class="detail-list compact-list">
        <li>Backend and systems roles</li>
        <li>Early-stage startups</li>
        <li>Technically challenging problems</li>
      </ul>
    </article>
  </section>
</Layout>
